# ============================================
# CONFIGURACIÓN DEMO - DATABASE CACHE/QUEUE
# ============================================
# Copia este archivo a .env.docker para usar
# database en lugar de Redis (versión demo)

# ===== DRIVERS DE CACHE Y QUEUE =====
CACHE_STORE=database
QUEUE_CONNECTION=database
SESSION_DRIVER=database

# ===== CONFIGURACIÓN DE DATABASE =====
DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=Intellipost
DB_USERNAME=contenflow
DB_PASSWORD=Asd12345--

# Configuración de caché database
DB_CACHE_CONNECTION=pgsql
DB_CACHE_TABLE=cache

# Configuración de colas database
DB_QUEUE_CONNECTION=pgsql
DB_QUEUE_TABLE=jobs
DB_QUEUE=default
DB_QUEUE_RETRY_AFTER=90

# Conexiones persistentes (mejora performance)
DB_PERSISTENT=true

# ===== OCTANE OPTIMIZADO PARA DATABASE =====
OCTANE_SERVER=swoole
OCTANE_WORKERS=2
OCTANE_MAX_REQUESTS=500
OCTANE_TASK_WORKERS=1

# ===== REDIS (MANTENER PARA REVERB) =====
# Nota: Reverb WebSockets aún requiere Redis
BROADCAST_CONNECTION=reverb
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379

# ===== RESTO DE CONFIGURACIÓN =====
# (Copiar del .env.docker original)
APP_NAME=Contenflow
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost

# ... resto de variables ...
