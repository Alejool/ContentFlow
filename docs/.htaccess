# ContentFlow API Documentation - Apache Configuration

# Enable rewrite engine
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /docs/

    # Redirect root to index.html
    RewriteRule ^$ index.html [L]

    # Auto-detect language for markdown downloads
    RewriteCond %{HTTP:Accept-Language} ^es [NC]
    RewriteRule ^download-markdown$ API_ENTERPRISE_V1.md [L]
    RewriteRule ^download-markdown$ API_ENTERPRISE_V1.en.md [L]

    # Auto-detect language for OpenAPI downloads
    RewriteCond %{HTTP:Accept-Language} ^es [NC]
    RewriteRule ^download-openapi$ api-auth-openapi.json [L]
    RewriteRule ^download-openapi$ api-auth-openapi.en.json [L]
</IfModule>

# Set correct MIME types
<IfModule mod_mime.c>
    AddType text/markdown .md
    AddType application/json .json
    AddType text/html .html
</IfModule>

# Enable CORS for API documentation
<IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "*"
    Header set Access-Control-Allow-Methods "GET, OPTIONS"
    Header set Access-Control-Allow-Headers "Content-Type"
</IfModule>

# Compression for better performance
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/markdown application/json
</IfModule>

# Cache control
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html "access plus 1 hour"
    ExpiresByType text/markdown "access plus 1 day"
    ExpiresByType application/json "access plus 1 day"
</IfModule>

# Prevent directory listing
Options -Indexes

# Custom error pages
ErrorDocument 404 /docs/index.html
