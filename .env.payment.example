# ============================================================================
# CONFIGURACIÓN DE PASARELAS DE PAGO - Intellipost
# ============================================================================
#
# Este archivo contiene las variables de entorno necesarias para configurar
# múltiples pasarelas de pago según el país del usuario.
#
# IMPORTANTE: Copiar las variables necesarias a tu archivo .env o .env.docker
#
# ============================================================================

# ----------------------------------------------------------------------------
# CONFIGURACIÓN GENERAL DE PAGOS
# ----------------------------------------------------------------------------

# Gateway por defecto (stripe, mercadopago, epayco, payu)
PAYMENT_DEFAULT_GATEWAY=stripe

# Gateway preferido para Colombia
PAYMENT_GATEWAY_CO=wompi

# ----------------------------------------------------------------------------
# STRIPE (Global - Países desarrollados)
# ----------------------------------------------------------------------------
# Documentación: https://stripe.com/docs
# Dashboard: https://dashboard.stripe.com/

STRIPE_SECRET=sk_test_YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_PUBLISH=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# IDs de precios en Stripe (crear en Dashboard)
STRIPE_STARTER_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_PROFESSIONAL_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_ENTERPRISE_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_GROWTH_PRICE_ID=price_xxxxxxxxxxxxx

# IDs de precios para addons
STRIPE_AI_100_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_AI_500_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_AI_1000_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_AI_5000_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_STORAGE_10GB_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_STORAGE_50GB_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_STORAGE_100GB_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_STORAGE_500GB_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_MEMBERS_5_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_MEMBERS_10_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_MEMBERS_25_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_POSTS_50_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_POSTS_100_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_POSTS_250_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_POSTS_500_PRICE_ID=price_xxxxxxxxxxxxx

# ----------------------------------------------------------------------------
# MERCADO PAGO (Colombia, México, Argentina, Brasil, Chile, Perú, Uruguay)
# ----------------------------------------------------------------------------
# Documentación: https://www.mercadopago.com.co/developers/es/docs
# Dashboard: https://www.mercadopago.com.co/developers/panel

MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MERCADOPAGO_API_URL=https://api.mercadopago.com
MERCADOPAGO_USD_TO_COP_RATE=4000
MERCADOPAGO_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------------------------------------------------------
# EPAYCO (Colombia)
# ----------------------------------------------------------------------------
# Documentación: https://docs.epayco.co/
# Dashboard: https://dashboard.epayco.co/

EPAYCO_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EPAYCO_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EPAYCO_TEST_MODE=true
EPAYCO_USD_TO_COP_RATE=4000
EPAYCO_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------------------------------------------------------
# PAYU (Colombia, México, Perú, Argentina, Brasil, Chile, Panamá)
# ----------------------------------------------------------------------------
# Documentación: https://developers.payulatam.com/
# Dashboard: https://merchants.payulatam.com/

PAYU_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYU_API_LOGIN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYU_MERCHANT_ID=xxxxxx
PAYU_ACCOUNT_ID=xxxxxx
PAYU_TEST_MODE=true
PAYU_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Tasas de cambio para PayU (por país)
PAYU_USD_TO_COP_RATE=4000  # Colombia
PAYU_USD_TO_MXN_RATE=20    # México
PAYU_USD_TO_PEN_RATE=3.8   # Perú
PAYU_USD_TO_ARS_RATE=350   # Argentina
PAYU_USD_TO_BRL_RATE=5     # Brasil
PAYU_USD_TO_CLP_RATE=900   # Chile

# ----------------------------------------------------------------------------
# WOMPI (Bancolombia - Colombia)
# ----------------------------------------------------------------------------
# Documentación: https://docs.wompi.co/
# Dashboard: https://comercios.wompi.co/

# Test Keys (sandbox)
WOMPI_PUBLIC_KEY=pub_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WOMPI_PRIVATE_KEY=prv_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WOMPI_EVENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WOMPI_TEST_MODE=true

# Production Keys
# WOMPI_PUBLIC_KEY=pub_prod_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WOMPI_PRIVATE_KEY=prv_prod_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WOMPI_EVENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WOMPI_TEST_MODE=false

# ============================================================================
# INSTRUCCIONES DE CONFIGURACIÓN
# ============================================================================
#
# 1. STRIPE (Recomendado para países desarrollados)
#    - Crear cuenta en https://stripe.com
#    - Obtener claves API en Dashboard > Developers > API keys
#    - Crear productos y precios en Dashboard > Products
#    - Configurar webhook en Dashboard > Developers > Webhooks
#    - URL webhook: https://tudominio.com/webhooks/stripe
#
# 2. MERCADO PAGO (Recomendado para Latinoamérica)
#    - Crear cuenta en https://www.mercadopago.com.co
#    - Ir a Developers > Tus aplicaciones > Crear aplicación
#    - Obtener Access Token y Public Key
#    - Configurar notificaciones IPN
#    - URL notificación: https://tudominio.com/webhooks/mercadopago
#
# 3. EPAYCO (Específico para Colombia)
#    - Crear cuenta en https://epayco.co
#    - Ir a Dashboard > Configuración > Llaves API
#    - Obtener Public Key y Private Key
#    - Configurar URL de confirmación
#    - URL confirmación: https://tudominio.com/webhooks/epayco
#
# 4. PAYU (Multi-país Latinoamérica)
#    - Crear cuenta en https://www.payu.com
#    - Ir a Configuración > Integración
#    - Obtener API Key, API Login, Merchant ID, Account ID
#    - Configurar URL de confirmación
#    - URL confirmación: https://tudominio.com/webhooks/payu
#
# 5. WOMPI (Bancolombia - Colombia)
#    - Crear cuenta en https://comercios.wompi.co/
#    - Ir a Configuración > Llaves API
#    - Obtener Public Key, Private Key y Event Secret
#    - Configurar URL de eventos
#    - URL eventos: https://tudominio.com/webhooks/wompi
#
# ============================================================================
# TESTING
# ============================================================================
#
# Tarjetas de prueba:
#
# STRIPE:
#   - Éxito: 4242 4242 4242 4242
#   - Falla: 4000 0000 0000 0002
#   - CVV: cualquier 3 dígitos
#   - Fecha: cualquier fecha futura
#
# MERCADO PAGO:
#   - Éxito: 5031 7557 3453 0604
#   - Falla: 5031 4332 1540 6351
#   - CVV: 123
#   - Fecha: 11/25
#
# EPAYCO:
#   - Éxito: 4575 6231 0476 6372
#   - Falla: 4151 6112 2222 2222
#   - CVV: 123
#   - Fecha: 12/25
#
# PAYU:
#   - Éxito: 4097 4400 0000 0008
#   - Falla: 4111 1111 1111 1111
#   - CVV: 777
#   - Fecha: 01/25
#
# WOMPI:
#   - Éxito: 4242 4242 4242 4242
#   - Falla: 4111 1111 1111 1111
#   - CVV: 123
#   - Fecha: cualquier fecha futura
#   - También soporta: PSE, Nequi, Bancolombia Transfer (en sandbox)
#
# ============================================================================
