# Docker Environment Configuration
# Copy this file to .env.docker and configure with your values

APP_NAME=Intellipost
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost
ASSET_URL=${APP_URL}/
VITE_HMR_HOST=localhost
VITE_DEV_SERVER_URL=http://localhost:5173

SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_US

# Database Configuration (Docker)
DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=ContentFlow
DB_USERNAME=Intellipost
DB_PASSWORD=your_secure_password_here
DB_ROOT_PASSWORD=root

# Redis Configuration (Docker)
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# Reverb Configuration (Docker)
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT_WS=8081
VITE_REVERB_PORT_WSS=443
VITE_REVERB_SCHEME=http

# Session & Cache
SESSION_DRIVER=redis
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis

# See .env.example for all other configuration options
