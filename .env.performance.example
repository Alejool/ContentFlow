# ============================================
# PERFORMANCE OPTIMIZATION CONFIGURATION
# ============================================
# Add these variables to your .env.docker file

# ============================================
# CACHE CONFIGURATION
# ============================================
CACHE_STORE=redis
REDIS_CACHE_CONNECTION=cache

# Cache TTLs (in seconds)
CACHE_MEDIA_TTL=7200          # 2 hours
CACHE_PUBLICATION_TTL=3600    # 1 hour
CACHE_QUERY_TTL=1800          # 30 minutes

# ============================================
# CDN CONFIGURATION
# ============================================
CDN_ENABLED=true
CDN_PROVIDER=cloudfront       # cloudfront, cloudflare, or custom
CDN_DOMAIN=https://d1234567890.cloudfront.net

# Signed URLs (optional - for private content)
CDN_USE_SIGNED_URLS=false
CDN_PRIVATE_KEY_PATH=/var/www/html/storage/keys/cloudfront-private-key.pem
CDN_KEY_PAIR_ID=APKAXXXXXXXXXXXXXXXX

# CloudFront Configuration
CLOUDFRONT_DISTRIBUTION_ID=E1234567890ABC

# Cloudflare Configuration (if using Cloudflare)
CLOUDFLARE_ZONE_ID=your-zone-id-here
CLOUDFLARE_API_TOKEN=your-api-token-here

# ============================================
# IMAGE OPTIMIZATION
# ============================================
CDN_IMAGE_OPTIMIZATION=true

# Image quality settings (0-100)
IMAGE_QUALITY_WEBP=85
IMAGE_QUALITY_AVIF=80
IMAGE_QUALITY_JPEG=90

# Enable AVIF format (requires libavif)
IMAGE_ENABLE_AVIF=true

# ============================================
# QUEUE CONFIGURATION
# ============================================
QUEUE_CONNECTION=redis
REDIS_QUEUE_CONNECTION=default

# Queue retry settings
QUEUE_RETRY_AFTER=2100        # 35 minutes

# Horizon configuration
HORIZON_MEMORY_LIMIT=128      # MB
HORIZON_BALANCE=auto          # auto, simple, false

# ============================================
# AWS CONFIGURATION (if using S3/CloudFront)
# ============================================
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=your-bucket-name
AWS_URL=https://your-bucket.s3.amazonaws.com

# ============================================
# PERFORMANCE MONITORING
# ============================================
# Enable query logging for optimization
DB_LOG_QUERIES=false
DB_SLOW_QUERY_THRESHOLD=1000  # milliseconds

# Enable cache hit/miss logging
CACHE_LOG_HITS=false

# ============================================
# OPTIMIZATION FLAGS
# ============================================
# Auto-optimize images on upload
AUTO_OPTIMIZE_IMAGES=true

# Auto-generate derivatives
AUTO_GENERATE_DERIVATIVES=true

# Preload frequently accessed content
PRELOAD_FREQUENT_CONTENT=true

# ============================================
# NOTES
# ============================================
# 1. Restart services after changing these values:
#    docker-compose restart app queue
#
# 2. Clear caches after configuration changes:
#    docker-compose exec app php artisan cache:clear
#    docker-compose exec app php artisan config:cache
#
# 3. Monitor performance:
#    - Horizon: /horizon
#    - Redis Commander: http://localhost:8082
#    - Logs: docker-compose logs -f app queue
