# ============================================
# ADD-ONS STRIPE PRICE IDS
# ============================================
# Configura los Price IDs de Stripe para cada paquete de add-on
# Estos IDs se obtienen desde el Dashboard de Stripe después de crear los productos

# ============================================
# AI CREDITS ADD-ONS
# ============================================
STRIPE_AI_100_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_AI_500_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_AI_1000_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_AI_5000_PRICE_ID=price_xxxxxxxxxxxxx

# ============================================
# STORAGE ADD-ONS
# ============================================
STRIPE_STORAGE_10GB_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_STORAGE_50GB_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_STORAGE_100GB_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_STORAGE_500GB_PRICE_ID=price_xxxxxxxxxxxxx

# ============================================
# PUBLICATIONS ADD-ONS
# ============================================
STRIPE_POSTS_50_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_POSTS_100_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_POSTS_250_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_POSTS_500_PRICE_ID=price_xxxxxxxxxxxxx

# ============================================
# TEAM MEMBERS ADD-ONS
# ============================================
STRIPE_MEMBERS_5_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_MEMBERS_10_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_MEMBERS_25_PRICE_ID=price_xxxxxxxxxxxxx

# ============================================
# NOTAS:
# ============================================
# 1. Crea los productos en Stripe Dashboard (https://dashboard.stripe.com/products)
# 2. Para cada producto, crea un precio (one-time payment)
# 3. Copia el Price ID (comienza con "price_") y pégalo aquí
# 4. Los precios deben coincidir con los definidos en config/addons.php
# ============================================
